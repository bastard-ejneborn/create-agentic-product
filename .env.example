# Image generation (Google Gemini via OpenRouter)
OPENROUTER_API_KEY=your-openrouter-api-key

# Voice generation (ElevenLabs)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Music generation (Suno) — used via web interface, no API key needed

# FreshService helpdesk (read-only)
FRESHSERVICE_DOMAIN=yourcompany
FRESHSERVICE_API_KEY=your-freshservice-api-key

# Google Stitch UI design (stitch.withgoogle.com)
STITCH_API_KEY=your-stitch-api-key

# Oracle Simphony BI API (read-only restaurant POS data)
SIMPHONY_HOST=https://yourdomain.oracleindustry.com
SIMPHONY_AUTH_HOST=https://yourdomain-idm.oracleindustry.com
SIMPHONY_CLIENT_ID=your-client-id
SIMPHONY_USERNAME=your-api-username
SIMPHONY_PASSWORD=your-api-password
SIMPHONY_ORG=your-org-short-name
